{
  "name": "litscript",
  "version": "2.4.0",
  "description": "LiTScript - Literate Interactive TypeScript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johtela/litscript.git"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node ./lib/src/tests/config-tests.js",
    "gendocs": "node ./lib/src/cli.js --deployMode prod",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "postversion": "git push && git push --tags"
  },
  "author": "Tommi Johtela",
  "license": "MPL-2.0",
  "keywords": [
    "typescript",
    "literate",
    "interactive",
    "compiler",
    "cli"
  ],
  "homepage": "https://johtela.github.io/litscript",
  "bin": {
    "lits": "lib/src/cli.js"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.5.0",
    "lits-extras": "^3.0.0",
    "taitto": "^1.2.0"
  },
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "esbuild": "^0.27.5",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "minimatch": "^10.2.5",
    "typescript": "^6.0.2"
  }
}
